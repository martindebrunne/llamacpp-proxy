{
  "name": "llamacpp-proxy",
  "version": "1.1.0",
  "description": "OpenAI-compatible proxy server for llama.cpp with dynamic model detection and thinking mode support",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsc && node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "llama.cpp",
    "proxy",
    "openai",
    "ai",
    "llm",
    "inference"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/martindebrunne/llamacpp-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/martindebrunne/llamacpp-proxy/issues"
  },
  "homepage": "https://github.com/martindebrunne/llamacpp-proxy#readme",
  "dependencies": {
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/http-proxy-middleware": "^0.19.3",
    "@types/node": "^25.5.2",
    "supertest": "^7.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
